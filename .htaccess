Redirect 301 /about-us/office-virtual-tours/ /about/team/
Redirect 301 /about-us/smiles-for-hope-foundation /about/team/
Redirect 301 /about-us/smiles-for-hope-foundation/ /about/team/

# ── Treatments → Orthodontics ──
Redirect 301 /treatments /orthodontics/
