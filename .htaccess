Options -Indexes
RewriteEngine On

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 301 REDIRECTS — lach-ortho.com legacy URLs
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ── About ──
Redirect 301 /about-us /about/team/
Redirect 301 /about-us/ /about/team/
Redirect 301 /about-us/meet-dr-lach /about/doctor/
Redirect 301 /about-us/meet-dr-lach/ /about/doctor/
Redirect 301 /about-us/meet-the-team /about/team/
Redirect 301 /about-us/meet-the-team/ /about/team/
