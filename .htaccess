# ── New Patients ──
Redirect 301 /new-patients /orthodontics/new-patients/free-consultation/
Redirect 301 /new-patients/ /orthodontics/new-patients/free-consultation/
Redirect 301 /new-patients/free-in-office-consultation /orthodontics/new-patients/free-consultation/
Redirect 301 /new-patients/free-in-office-consultation/ /orthodontics/new-patients/free-consultation/
Redirect 301 /new-patients/free-digital-consultation /orthodontics/new-patients/digital-consultation/
Redirect 301 /new-patients/free-digital-consultation/ /orthodontics/new-patients/digital-consultation/
Redirect 301 /new-patients/verify-my-insurance /orthodontics/new-patients/verify-insurance/
Redirect 301 /new-patients/verify-my-insurance/ /orthodontics/new-patients/verify-insurance/
Redirect 301 /new-patients/orthodontist-vs-dentist /orthodontics/new-patients/free-consultation/
Redirect 301 /new-patients/orthodontist-vs-dentist/ /orthodontics/new-patients/free-consultation/

# ── Active Patients ──
Redirect 301 /active-patients /orthodontics/active-patients/virtual-appointments/
Redirect 301 /active-patients/ /orthodontics/active-patients/virtual-appointments/
Redirect 301 /active-patients/patient-forms /orthodontics/new-patients/patient-forms/
Redirect 301 /active-patients/patient-forms/ /orthodontics/new-patients/patient-forms/
Redirect 301 /active-patients/orthodontic-faqs /orthodontics/active-patients/faqs/
Redirect 301 /active-patients/orthodontic-faqs/ /orthodontics/active-patients/faqs/
Redirect 301 /active-patients/emergency-information /orthodontics/active-patients/emergency/
Redirect 301 /active-patients/emergency-information/ /orthodontics/active-patients/emergency/

# ── Success Stories ──
Redirect 301 /success-stories /orthodontics/success-stories/smile-gallery/
Redirect 301 /success-stories/ /orthodontics/success-stories/smile-gallery/
Redirect 301 /success-stories/smile-gallery /orthodontics/success-stories/smile-gallery/
Redirect 301 /success-stories/smile-gallery/ /orthodontics/success-stories/smile-gallery/
Redirect 301 /success-stories/reviews /orthodontics/success-stories/reviews/
Redirect 301 /success-stories/reviews/ /orthodontics/success-stories/reviews/

# ── Contact / Locations ──
Redirect 301 /contact-us /lake-nona/
Redirect 301 /contact-us/ /lake-nona/
Redirect 301 /contact-us/oviedo-office /oviedo/
Redirect 301 /contact-us/oviedo-office/ /oviedo/
Redirect 301 /contact-us/lake-nona-office /lake-nona/
Redirect 301 /contact-us/lake-nona-office/ /lake-nona/

# ── Blog ──
Redirect 301 /blog /orthodontics/about/blog/
Redirect 301 /blog/ /orthodontics/about/blog/
RedirectMatch 301 ^/blog/(.*)$ /orthodontics/about/blog/

# ── Legal ──
Redirect 301 /terms-and-conditions /terms-of-service/
Redirect 301 /terms-and-conditions/ /terms-of-service/
Redirect 301 /cookies-policy /privacy-policy/
Redirect 301 /cookies-policy/ /privacy-policy/

# ── Survey ──
Redirect 301 /survey.php /orthodontics/survey_orthodontics.php

# ── Remove trailing slashes (except root) ──
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)/$ /$1 [R=301,L]

# Route clean URLs to index.php in matching directory
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([a-z0-9-]+)/?$ /$1/index.php [L]

# Security headers
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set X-XSS-Protection "1; mode=block"
</IfModule>

# php -- BEGIN cPanel-generated handler, do not edit
# Set the “ea-php84” package as the default “PHP” programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php84 .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit
