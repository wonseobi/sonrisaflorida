Redirect 301 /treatments/tmj-and-sleep-apnea /orthodontics/
Redirect 301 /treatments/tmj-and-sleep-apnea/ /orthodontics/
Redirect 301 /treatments/smile-makeover-dentist /orthodontics/
Redirect 301 /treatments/smile-makeover-dentist/ /orthodontics/
Redirect 301 /treatments/teeth-whitening /orthodontics/
Redirect 301 /treatments/teeth-whitening/ /orthodontics/
Redirect 301 /treatments/retainer-insurance /orthodontics/new-patients/verify-insurance/
